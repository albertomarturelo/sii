{
  "name": "sii-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Monorepo: a shared TypeScript SII core consumed by a CLI and an MCP server (Claude Code + Claude Desktop).",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "tsc -b --clean",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint packages",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@types/node": "^20.16.0",
    "eslint": "^9.14.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.0"
  }
}
