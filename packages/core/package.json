{
  "name": "@albertomarturelo/sii-core",
  "version": "0.4.0",
  "type": "module",
  "description": "Shared SII domain core: rut, config (prod hostnames), contracts, tasks, seams. A Node library; external side-effects (portal, secrets, audit, clock) are injected via seams (ADR-003).",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/albertomarturelo/sii.git",
    "directory": "packages/core"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    },
    "./node": {
      "types": "./dist/node.d.ts",
      "default": "./dist/node.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc -b",
    "prepack": "rm -rf dist tsconfig.tsbuildinfo && tsc -b"
  },
  "dependencies": {
    "zod": "^4.4.3"
  },
  "peerDependencies": {
    "playwright": "^1.49.0"
  },
  "peerDependenciesMeta": {
    "playwright": {
      "optional": true
    }
  },
  "devDependencies": {
    "playwright": "^1.49.0"
  }
}
