{
  "name": "@sii/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shared SII domain core: rut, config (prod hostnames), contracts, tasks, ports. Runtime-agnostic; platform side-effects are injected via ports (ADR-003).",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": {
      "types": "./dist/cli.d.ts",
      "default": "./dist/cli.js"
    }
  },
  "scripts": {
    "build": "tsc -b"
  },
  "dependencies": {
    "playwright": "^1.49.0",
    "zod": "^4.4.3"
  }
}
